{
  "name": "hexamind-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:backend": "python3 -m uvicorn main:app --app-dir ai-service --host 127.0.0.1 --port 8000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:backend": "python3 -m unittest discover -s ai-service/tests -p 'test_*.py'",
